---
import { getDict, type Lang } from '../i18n';
import { SITE } from '../config/site';
import { withBase } from '../lib/url';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);

type Slot = { logo: string | null; name: string | null; url: string | null; offsetY?: number; scale?: number };

const slotStyle = (slot: Slot) => {
  const parts = [];
  if (slot.offsetY) parts.push(`translateY(${slot.offsetY}%)`);
  if (slot.scale) parts.push(`scale(${slot.scale})`);
  return parts.length ? `transform: ${parts.join(' ')}` : undefined;
};

const hoverClass = (slot: Slot) =>
  slot.logo && slot.url ? 'hover:-translate-y-1 hover:shadow-md' : '';
---

<section id="patrocinios" data-animate="fade-up" class="bg-white py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <h2 class="text-4xl md:text-5xl text-ink mb-3">{t.patrocinios.title}</h2>
    <p class="text-lg text-ink/70 max-w-2xl mb-12">{t.patrocinios.intro}</p>

    <div class="flex flex-wrap justify-center gap-3">
      {SITE.sponsors.map((slot) => (
        <div
          class:list={[
            'flex items-center justify-center rounded-xl transition h-32 md:h-36',
            'basis-[calc((100%_-_1.5rem)/3)] md:basis-[calc((100%_-_3rem)/5)] grow-0 shrink-0',
            slot.logo
              ? 'bg-cream'
              : 'border-2 border-dashed border-ink/15 bg-cream/40 text-ink/40 hover:border-teal/40 hover:text-teal/60',
            hoverClass(slot),
          ]}
        >
          {slot.logo ? (
            slot.url ? (
              <a href={slot.url} target="_blank" rel="noopener" class="block w-full h-full flex items-center justify-center p-4">
                <img src={withBase(slot.logo)} alt={slot.name ?? ''} class="max-h-full max-w-full object-contain" style={slotStyle(slot)} />
              </a>
            ) : (
              <img src={withBase(slot.logo)} alt={slot.name ?? ''} class="max-h-full max-w-full object-contain p-4" style={slotStyle(slot)} />
            )
          ) : (
            <span class="text-xs uppercase tracking-wider">{t.patrocinios.espacoDisponivel}</span>
          )}
        </div>
      ))}
    </div>

    <div class="mt-16 p-8 md:p-10 bg-teal text-cream rounded-2xl flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <p class="text-xl md:text-2xl max-w-2xl">{t.patrocinios.pitch}</p>
      <a
        href="mailto:caia.triathlon.ataa@gmail.com?subject=Patrocínio%20CAIA%20Spirit%20of%20Triathlon"
        class="inline-flex items-center gap-2 bg-gold hover:bg-gold-700 text-ink font-semibold px-6 py-3 rounded-full uppercase tracking-wider text-sm transition-colors shrink-0"
      >
        {t.patrocinios.cta}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
