---
import { getDict, type Lang } from '../i18n';
import { SITE } from '../config/site';
import { withBase } from '../lib/url';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);

type Slot = { logo: string | null; name: string | null; url: string | null };

const tierClasses = {
  principais: 'h-40 md:h-48',
  apoios: 'h-28 md:h-32',
  parceiros: 'h-20 md:h-24',
};

const tierGrid = {
  principais: 'grid-cols-1 md:grid-cols-3 gap-4',
  apoios: 'grid-cols-2 md:grid-cols-4 gap-3',
  parceiros: 'grid-cols-3 md:grid-cols-6 gap-3',
};

const Tier = ({ items, kind, label }: { items: Slot[]; kind: keyof typeof tierClasses; label: string }) => null; // typed-only helper
---

<section id="patrocinios" class="bg-white py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <h2 class="text-4xl md:text-5xl text-ink mb-3">{t.patrocinios.title}</h2>
    <p class="text-lg text-ink/70 max-w-2xl mb-12">{t.patrocinios.intro}</p>

    {(['principais', 'apoios', 'parceiros'] as const).map((tier) => (
      <div class="mb-12 last:mb-0">
        <h3 class="text-sm uppercase tracking-[0.25em] text-teal font-semibold mb-5">
          {t.patrocinios.tiers[tier]}
        </h3>
        <div class:list={['grid', tierGrid[tier]]}>
          {SITE.sponsors[tier].map((slot) => (
            <div
              class:list={[
                'flex items-center justify-center rounded-xl transition',
                tierClasses[tier],
                slot.logo
                  ? 'bg-cream'
                  : 'border-2 border-dashed border-ink/15 bg-cream/40 text-ink/40 hover:border-teal/40 hover:text-teal/60',
              ]}
            >
              {slot.logo ? (
                slot.url ? (
                  <a href={slot.url} target="_blank" rel="noopener" class="block w-full h-full flex items-center justify-center p-4">
                    <img src={withBase(slot.logo)} alt={slot.name ?? ''} class="max-h-full max-w-full object-contain" />
                  </a>
                ) : (
                  <img src={withBase(slot.logo)} alt={slot.name ?? ''} class="max-h-full max-w-full object-contain p-4" />
                )
              ) : (
                <span class="text-xs uppercase tracking-wider">{t.patrocinios.espacoDisponivel}</span>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="mt-16 p-8 md:p-10 bg-teal text-cream rounded-2xl flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <p class="text-xl md:text-2xl max-w-2xl">{t.patrocinios.pitch}</p>
      <a
        href="mailto:caia.triathlon.ataa@gmail.com?subject=Patrocínio%20CAIA%20Spirit%20of%20Triathlon"
        class="inline-flex items-center gap-2 bg-gold hover:bg-gold-700 text-ink font-semibold px-6 py-3 rounded-full uppercase tracking-wider text-sm transition-colors shrink-0"
      >
        {t.patrocinios.cta}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
