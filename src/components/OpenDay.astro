---
import { getDict, type Lang } from '../i18n';
import { SITE } from '../config/site';
import { withBase } from '../lib/url';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);

type LegIcon = 'swim' | 'bike' | 'run';
const legImageFor = (icon: string): string | null => {
  return SITE.openDayImages[icon as LegIcon] ?? null;
};
---

<section id="open-day" data-animate="fade-up" class="bg-cream py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <p class="text-teal uppercase tracking-[0.25em] text-sm font-semibold mb-4">
      {t.openDay.label}
    </p>

    <h2 class="leading-none mb-3">
      <span class="block text-7xl md:text-9xl font-display tracking-tight">
        <span class="text-teal">{t.openDay.titlePart1}</span>
        <span class="text-gold"> {t.openDay.titlePart2}</span>
      </span>
      <span class="block text-2xl md:text-3xl text-ink/80 mt-3 font-display tracking-wide">
        {t.openDay.subtitle}
      </span>
    </h2>

    <p class="text-lg md:text-xl text-ink/70 italic mt-2 mb-10 max-w-2xl">
      {t.openDay.tagline}
    </p>

    <!-- Date / Time / Location bar -->
    <div class="flex flex-wrap gap-x-8 gap-y-3 text-ink/80 text-base md:text-lg mb-12 pb-8 border-b border-ink/10">
      <span class="flex items-center gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <strong class="text-ink">{t.openDay.date}</strong> · {t.openDay.weekday}
      </span>
      <span class="flex items-center gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <strong class="text-ink">{t.openDay.time}</strong>
      </span>
      <span class="flex items-center gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <strong class="text-ink">{t.openDay.location}</strong>
      </span>
    </div>

    <!-- 3-column athlete image strip with overlaid distance + sport -->
    <div class="grid grid-cols-3 gap-2 md:gap-4 mb-14">
      {t.openDay.legs.map((leg) => {
        const photo = legImageFor(leg.icon);
        return (
          <div class="relative aspect-[4/3] md:aspect-[3/2] bg-gradient-to-br from-teal-700 via-teal to-teal-900 overflow-hidden rounded-2xl transition-all duration-300 ease-out hover:scale-[1.03] hover:shadow-2xl hover:shadow-teal-900/40 hover:z-10">
            {photo ? (
              <img src={withBase(photo)} alt={leg.label} class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center">
                {leg.icon === 'swim' && (
                  <svg viewBox="0 0 64 64" class="w-1/2 h-1/2 text-cream/30" fill="currentColor">
                    <circle cx="46" cy="14" r="6"/>
                    <path d="M14 36c5 0 8-3 13-3s8 3 13 3c4 0 7-2 10-3l-1-7c-2 1-5 3-9 3-5 0-8-3-13-3-3 0-6 1-9 2l-2-9-7 1 5 16z"/>
                    <path d="M4 50c4 0 4-3 8-3s5 3 9 3 4-3 8-3 5 3 9 3 4-3 8-3 5 3 9 3 4-3 8-3v-6c-4 0-4 3-8 3s-5-3-9-3-4 3-8 3-5-3-9-3-4 3-8 3-5-3-9-3-4 3-8 3v6z"/>
                  </svg>
                )}
                {leg.icon === 'bike' && (
                  <svg viewBox="0 0 64 64" class="w-1/2 h-1/2 text-cream/30" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="14" cy="46" r="11" fill="none"/>
                    <circle cx="50" cy="46" r="11" fill="none"/>
                    <circle cx="40" cy="14" r="3" fill="currentColor"/>
                    <path d="M32 46V36L23 26h12l8 11h7"/>
                  </svg>
                )}
                {leg.icon === 'run' && (
                  <svg viewBox="0 0 64 64" class="w-1/2 h-1/2 text-cream/30" fill="currentColor">
                    <circle cx="42" cy="12" r="6"/>
                    <path d="M40 22c-3 0-5 2-7 4l-7 7 8 6-3 9 4 8h6l-3-12 6-7 5 3v8h6V36l-8-7c-1-3-3-7-7-7z"/>
                    <path d="M22 38l-7 4-5 7 5 3 4-5 6-3-3-6z"/>
                  </svg>
                )}
              </div>
            )}

            <!-- Bottom overlay strip -->
            <div class="absolute inset-x-0 bottom-0 px-4 md:px-6 py-4 md:py-5 bg-gradient-to-t from-teal-900/95 via-teal-900/70 to-transparent">
              <div class="text-gold text-3xl md:text-5xl font-display tracking-wide leading-none">
                {leg.distance}
              </div>
              <div class="text-cream text-xs md:text-sm uppercase tracking-[0.2em] font-semibold mt-1.5">
                {leg.label}
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <p class="text-xl md:text-2xl text-ink/85 max-w-3xl mb-12 leading-relaxed">
      {t.openDay.intro}
    </p>

    <!-- 4 fact badges (matching poster bottom row) -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 mb-14">
      {t.openDay.facts.map((fact) => (
        <div class="text-center">
          <div class:list={[
            'w-24 h-24 md:w-28 md:h-28 mx-auto rounded-full flex items-center justify-center mb-4',
            fact.icon === 'donation' ? 'bg-gold' : 'bg-teal/10 ring-1 ring-teal/30',
          ]}>
            {fact.icon === 'donation' && fact.badge && (
              <span class="text-3xl md:text-4xl font-display tracking-wide text-ink">
                {fact.badge}
              </span>
            )}
            {fact.icon === 'people' && (
              <svg viewBox="0 0 48 48" class="w-12 h-12 md:w-14 md:h-14 text-teal" fill="currentColor">
                <circle cx="24" cy="14" r="6"/>
                <circle cx="10" cy="17" r="4.5"/>
                <circle cx="38" cy="17" r="4.5"/>
                <path d="M24 22c-7 0-13 4-13 10v4h26v-4c0-6-6-10-13-10z"/>
                <path d="M10 25c-4 0-7 2.5-7 6v3h6v-3c0-2 .8-3.5 2-5z"/>
                <path d="M38 25c4 0 7 2.5 7 6v3h-6v-3c0-2-.8-3.5-2-5z"/>
              </svg>
            )}
            {fact.icon === 'drink' && (
              <svg viewBox="0 0 48 48" class="w-12 h-12 md:w-14 md:h-14 text-teal" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 18h20l-2 22a3 3 0 0 1-3 3H19a3 3 0 0 1-3-3z" fill="currentColor" stroke="none"/>
                <path d="M14 18h20"/>
                <path d="M24 18V8"/>
                <path d="M22 8h6"/>
              </svg>
            )}
            {fact.icon === 'kit' && (
              <svg viewBox="0 0 24 24" class="w-12 h-12 md:w-14 md:h-14 text-teal" fill="currentColor">
                <path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/>
              </svg>
            )}
          </div>
          <p class="text-sm md:text-base text-ink/85 leading-snug max-w-[180px] mx-auto">
            {fact.label}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-6 flex-wrap">
      <a
        href={SITE.lumaEventUrl}
        data-luma-action="checkout"
        data-luma-event-id={SITE.lumaEventId}
        class="inline-flex items-center gap-2 bg-teal hover:bg-teal-700 text-cream font-semibold px-8 py-4 rounded-full uppercase tracking-wider text-sm transition-colors"
      >
        {t.openDay.cta}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <span
        aria-disabled="true"
        class="inline-flex items-center gap-1.5 text-ink/30 text-sm font-medium underline underline-offset-4 decoration-ink/15 cursor-not-allowed select-none"
        title="Em breve"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16"/>
        </svg>
        {t.openDay.downloads.regulamento}
      </span>
      <span
        aria-disabled="true"
        class="inline-flex items-center gap-1.5 text-ink/30 text-sm font-medium underline underline-offset-4 decoration-ink/15 cursor-not-allowed select-none"
        title="Em breve"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16"/>
        </svg>
        {t.openDay.downloads.percursos}
      </span>
    </div>
  </div>
</section>
