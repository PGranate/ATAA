---
import { getDict, type Lang } from '../i18n';
import { SITE } from '../config/site';
import { withBase } from '../lib/url';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);

const slides = SITE.heroSlides;
const slideCount = slides.length;
const totalDuration = Math.max(slideCount * 8, 8);
const slideStyle = `--hero-duration: ${totalDuration}s;`;
---

<section id="inicio" class="relative isolate overflow-hidden min-h-[88vh] flex items-center">
  <!-- Slides -->
  <div class="absolute inset-0 -z-10">
    {slides.map((slide, i) => (
      <div
        class:list={[
          'absolute inset-0',
          slideCount > 1 ? 'hero-slide' : '',
        ]}
        style={
          slideCount > 1
            ? `${slideStyle} animation-delay: ${(i * totalDuration) / slideCount}s;`
            : ''
        }
      >
        {slide.src ? (
          <img src={withBase(slide.src)} alt={slide.alt} class="w-full h-full object-cover" />
        ) : (
          <div class="w-full h-full bg-gradient-to-br from-teal-700 via-teal to-teal-900"></div>
        )}
        <div class="absolute inset-0 bg-gradient-to-r from-teal-900/85 via-teal-900/60 to-teal-900/30"></div>
      </div>
    ))}
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 md:px-6 py-24 md:py-32 w-full">
    <div class="max-w-2xl text-cream">
      <p class="text-gold uppercase tracking-[0.25em] text-sm font-semibold mb-4">
        {t.hero.eyebrow}
      </p>
      <h1 class="text-5xl md:text-7xl lg:text-8xl leading-[0.95] mb-6">
        {t.hero.title}
      </h1>
      <p class="text-xl md:text-2xl text-cream/90 mb-10 max-w-xl">
        {t.hero.tagline}
      </p>
      <a
        href={SITE.lumaEventUrl}
        data-luma-action="checkout"
        data-luma-event-id={SITE.lumaEventId}
        class="inline-flex items-center gap-2 bg-gold hover:bg-gold-700 text-ink font-semibold px-7 py-4 rounded-full uppercase tracking-wider text-sm transition-colors"
      >
        {t.hero.cta}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
