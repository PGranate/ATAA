---
import { getDict, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);
---

<section id="direcao" data-animate="fade-up" class="bg-white py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <h2 class="text-4xl md:text-5xl text-ink mb-12">{t.direcao.title}</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
      {t.direcao.groups.map((group) => (
        <div>
          <h3 class="text-sm uppercase tracking-[0.25em] text-teal font-semibold mb-5 pb-3 border-b border-ink/10">
            {group.title}
          </h3>
          <ul class="space-y-4">
            {group.members.map((member) => (
              <li>
                <div class="text-base font-semibold text-ink leading-tight">{member.name}</div>
                <div class="text-xs uppercase tracking-wider text-ink/55 mt-1">{member.role}</div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
