---
import { getDict, type Lang } from '../i18n';
import { SITE } from '../config/site';
import { withBase } from '../lib/url';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);

const members = t.direcao.members.map((m, i) => ({
  ...m,
  photo: SITE.team[i]?.photo ?? null,
}));
---

<section id="direcao" class="bg-white py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <h2 class="text-4xl md:text-5xl text-ink mb-12">{t.direcao.title}</h2>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 md:gap-8">
      {members.map((member) => (
        <div class="text-center">
          <div class="aspect-square rounded-full overflow-hidden bg-cream border-2 border-ink/5 mb-4 mx-auto max-w-[180px]">
            {member.photo ? (
              <img src={withBase(member.photo)} alt={member.name} class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-teal/15 to-gold/15 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-ink/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
            )}
          </div>
          <div class="text-base font-semibold text-ink">{member.name}</div>
          <div class="text-sm uppercase tracking-wider text-ink/60 mt-1">{member.role}</div>
        </div>
      ))}
    </div>
  </div>
</section>
