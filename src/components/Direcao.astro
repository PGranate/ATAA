---
import { getDict, type Lang } from '../i18n';
import { withBase } from '../lib/url';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);
---

<section id="direcao" data-animate="fade-up" class="bg-white py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <h2 class="text-4xl md:text-5xl text-ink mb-12">{t.direcao.title}</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
      {t.direcao.groups.map((group) => (
        <div>
          <h3 class="text-sm uppercase tracking-[0.25em] text-teal font-semibold mb-5 pb-3 border-b border-ink/10">
            {group.title}
          </h3>
          <ul class="space-y-4">
            {group.members.map((member) => (
              <li>
                <div class="text-base font-semibold text-ink leading-tight">{member.name}</div>
                <div class="text-xs uppercase tracking-wider text-ink/55 mt-1">{member.role}</div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="mt-12 pt-8 border-t border-ink/10 text-sm text-ink/70 max-w-3xl">
      <span class="text-ink font-medium">{t.direcao.socio.question}</span>{' '}
      <a
        href={withBase('/docs/proposta-socio.pdf')}
        target="_blank"
        rel="noopener"
        class="underline underline-offset-2 decoration-ink/30 hover:text-teal hover:decoration-teal/60 transition-colors"
      >
        {t.direcao.socio.downloadLabel}
      </a>
      {' '}{t.direcao.socio.instruction}{' '}
      <a
        href={`mailto:${t.contactos.email}?subject=${encodeURIComponent('Proposta de Sócio')}`}
        class="underline underline-offset-2 decoration-ink/30 hover:text-teal hover:decoration-teal/60 transition-colors"
      >
        {t.contactos.email}
      </a>.
    </p>
  </div>
</section>
