---
import { getDict, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);
---

<footer class="bg-ink text-cream/70 py-8">
  <div class="max-w-7xl mx-auto px-4 md:px-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
    <p>{t.footer.copyright}</p>
  </div>
</footer>
