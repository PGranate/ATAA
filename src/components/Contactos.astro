---
import { getDict, type Lang } from '../i18n';
import { SITE } from '../config/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);
---

<section id="contactos" class="bg-teal-900 text-cream py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <h2 class="text-4xl md:text-5xl mb-12">{t.contactos.title}</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-3xl">
      <div>
        <div class="text-sm uppercase tracking-[0.2em] text-gold font-semibold mb-3">
          {t.contactos.emailLabel}
        </div>
        <a href={`mailto:${t.contactos.email}`} class="text-lg text-cream hover:text-gold transition-colors break-all">
          {t.contactos.email}
        </a>
      </div>

      <div>
        <div class="text-sm uppercase tracking-[0.2em] text-gold font-semibold mb-3">
          {t.contactos.locationLabel}
        </div>
        <p class="text-lg">{t.contactos.location}</p>
      </div>
    </div>

    <div class="mt-12 pt-10 border-t border-cream/10">
      <div class="text-sm uppercase tracking-[0.2em] text-gold font-semibold mb-4">
        {t.contactos.socialLabel}
      </div>
      <div class="flex items-center gap-4">
        <a
          href={SITE.socials.facebook}
          target="_blank"
          rel="noopener"
          class="w-12 h-12 rounded-full bg-cream/10 hover:bg-gold hover:text-ink flex items-center justify-center transition-colors"
          aria-label="Facebook"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/>
          </svg>
        </a>
        <a
          href={SITE.socials.instagram}
          target="_blank"
          rel="noopener"
          class="w-12 h-12 rounded-full bg-cream/10 hover:bg-gold hover:text-ink flex items-center justify-center transition-colors"
          aria-label="Instagram"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.92 5.92 0 00-2.13 1.39A5.92 5.92 0 00.62 4.14c-.3.76-.5 1.64-.56 2.91C0 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91a5.92 5.92 0 001.39 2.13c.62.62 1.27 1.01 2.13 1.39.76.3 1.64.5 2.91.56C8.33 24 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.92 5.92 0 002.13-1.39c.62-.62 1.01-1.27 1.39-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.92 5.92 0 00-1.39-2.13A5.92 5.92 0 0019.86.62c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 100 12.32 6.16 6.16 0 000-12.32zm0 10.16a4 4 0 110-8 4 4 0 010 8zm6.4-11.85a1.44 1.44 0 100 2.88 1.44 1.44 0 000-2.88z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
