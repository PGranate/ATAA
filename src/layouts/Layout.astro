---
import '../styles/global.css';
import { getDict, type Lang } from '../i18n';
import { withBase } from '../lib/url';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={t.meta.description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{t.meta.title}</title>
    <style is:global>
      [data-animate="fade-up"] {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        will-change: opacity, transform;
      }
      [data-animate="fade-up"].is-visible {
        opacity: 1;
        transform: translateY(0);
      }
      @media (prefers-reduced-motion: reduce) {
        [data-animate] {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
      }
    </style>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const obs = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          }
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });
        document.querySelectorAll('[data-animate]').forEach((el) => obs.observe(el));
      });
    </script>
    <!-- Luma embedded checkout — loads the script for its CSS, then we override
         click handlers below so the iframe URL includes ?locale={pageLang}.
         Luma's script only forwards `coupon` and `utm_source` — locale needs
         this manual rebind to reach the iframe. -->
    <script is:inline id="luma-checkout" src="https://embed.lu.ma/checkout-button.js"></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        const locale = document.documentElement.lang || 'pt';
        document.querySelectorAll('[data-luma-action="checkout"]').forEach((btn) => {
          const eventId = btn.dataset.lumaEventId;
          if (!eventId) return;
          btn.onclick = (e) => {
            e.preventDefault();
            const overlay = document.createElement('div');
            overlay.className = 'luma-checkout--overlay';

            const iframe = document.createElement('iframe');
            iframe.src = `https://luma.com/embed/event/${eventId}/simple?locale=${locale}`;
            iframe.allow = 'fullscreen; payment';
            iframe.style.cssText = 'border:0;width:100%;height:100%';
            iframe.onload = () => overlay.classList.add('luma-iframe-loaded');

            const modal = document.createElement('div');
            modal.className = 'luma-checkout--modal';
            modal.appendChild(iframe);

            const closeBtn = document.createElement('button');
            closeBtn.className = 'luma-checkout--close-btn';
            const closeImg = document.createElement('img');
            closeImg.src = 'https://embed.lu.ma/static/x.svg';
            closeBtn.appendChild(closeImg);

            const spinner = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            spinner.classList.add('luma-spinner');
            spinner.setAttribute('viewBox', '0 0 66 66');
            const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            ['fill:none', 'r:30', 'cx:33', 'cy:33', 'stroke-width:6', 'stroke-linecap:round'].forEach((p) => {
              const [k, v] = p.split(':');
              circle.setAttribute(k, v);
            });
            spinner.appendChild(circle);

            const credits = document.createElement('div');
            credits.className = 'luma-checkout--by';
            credits.textContent = 'Processed securely by — Luma';

            overlay.appendChild(closeBtn);
            overlay.appendChild(spinner);
            overlay.appendChild(modal);
            overlay.appendChild(credits);

            const close = () => overlay.remove();
            overlay.onclick = close;
            closeBtn.onclick = (ev) => { ev.stopPropagation(); close(); };

            document.body.appendChild(overlay);
            setTimeout(() => overlay.classList.add('luma-show'), 1);
          };
        });
      });
    </script>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
